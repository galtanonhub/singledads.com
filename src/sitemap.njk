---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
# LAUNCH FILE — generated sitemap for the production domain root (https://singledads.com/),
# NOT the /test/ staging path. It belongs at public_html/sitemap.xml at launch.
# Auto-built from every page in the site (collections.all); no hand-maintenance needed.
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all %}
{%- if page.url and page.url | last == "/" and "state.njk" not in page.inputPath %}
  <url>
    <loc>https://singledads.com{{ page.url }}</loc>
    <lastmod>{{ page.date | isoDate }}</lastmod>
    <changefreq>{% if page.url == "/" %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if page.url == "/" %}1.0{% else %}0.7{% endif %}</priority>
  </url>
{%- endif %}
{%- endfor %}
{#- Per-state legal pages: generated by src/legal/state.njk via pagination, which doesn't
    expose every paginated page in collections.all — so emit them straight from the data. -#}
{%- for state in states.list %}
  <url>
    <loc>https://singledads.com/legal/{{ state.slug }}/</loc>
    <lastmod>{{ null | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
{%- endfor %}
</urlset>
